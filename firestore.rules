rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function isSelf(userId) {
      return signedIn() && uid() == userId;
    }

    function activityPath(activityId) {
      return /databases/$(database)/documents/activities/$(activityId);
    }

    function activityExists(activityId) {
      return exists(activityPath(activityId));
    }

    function activityData(activityId) {
      return get(activityPath(activityId)).data;
    }

    function isActivityOwner(activityId) {
      return signedIn() &&
        activityExists(activityId) &&
        activityData(activityId).ownerUserId == uid();
    }

    function isRequester() {
      return signedIn() && resource.data.requesterId == uid();
    }

    function createsOwnRequest(activityId, requestId) {
      return signedIn() &&
        requestId == uid() &&
        request.resource.data.activityId == activityId &&
        request.resource.data.requesterId == uid() &&
        request.resource.data.status == 'pending';
    }

    function keepsRequestIdentity(activityId) {
      return request.resource.data.activityId == activityId &&
        request.resource.data.requesterId == resource.data.requesterId;
    }

    function isThreadParticipant() {
      return signedIn() && uid() in resource.data.participantIds;
    }

    function isNewThreadParticipant() {
      return signedIn() && uid() in request.resource.data.participantIds;
    }

    function publicActivityHasNoExactLocation() {
      return !request.resource.data.keys().hasAny([
        'exactLocation',
        'latitude',
        'longitude'
      ]);
    }

    match /profiles/{userId} {
      allow read: if signedIn();
      allow create, update: if isSelf(userId) &&
        request.resource.data.id == userId;
      allow delete: if false;
    }

    match /users/{userId}/notificationTokens/{tokenId} {
      allow read, create, update, delete: if isSelf(userId);
    }

    match /activities/{activityId} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        request.resource.data.ownerUserId == uid() &&
        publicActivityHasNoExactLocation();
      allow update: if signedIn() &&
        resource.data.ownerUserId == uid() &&
        request.resource.data.ownerUserId == resource.data.ownerUserId &&
        publicActivityHasNoExactLocation();
      allow delete: if signedIn() && resource.data.ownerUserId == uid();

      match /joinRequests/{requestId} {
        allow read: if isActivityOwner(activityId) || isRequester();
        allow create: if createsOwnRequest(activityId, requestId);
        allow update: if keepsRequestIdentity(activityId) && (
          (
            isActivityOwner(activityId) &&
            resource.data.status == 'pending' &&
            request.resource.data.status in ['approved', 'rejected']
          ) ||
          (
            isRequester() &&
            resource.data.status == 'pending' &&
            request.resource.data.status == 'cancelled'
          )
        );
        allow delete: if false;
      }
    }

    match /chatThreads/{threadId} {
      allow read: if isThreadParticipant();
      allow create: if isNewThreadParticipant();
      allow update: if isThreadParticipant() &&
        request.resource.data.participantIds == resource.data.participantIds;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if signedIn() &&
          uid() in get(/databases/$(database)/documents/chatThreads/$(threadId)).data.participantIds;
        allow create: if signedIn() &&
          uid() in get(/databases/$(database)/documents/chatThreads/$(threadId)).data.participantIds &&
          request.resource.data.senderUserId == uid();
        allow update, delete: if false;
      }
    }

    match /trustEvents/{eventId} {
      allow read: if signedIn() &&
        resource.data.subjectUserId == uid() &&
        resource.data.isUserVisible == true;
      allow create: if signedIn() &&
        request.resource.data.subjectUserId == uid() &&
        request.resource.data.isUserVisible == true;
      allow update, delete: if false;
    }

    match /reports/{reportId} {
      allow read: if signedIn() && resource.data.userId == uid();
      allow create: if signedIn() &&
        request.resource.data.userId == uid() &&
        request.resource.data.targetUserId is string &&
        request.resource.data.reason is string;
      allow update, delete: if false;
    }

    match /blocks/{blockId} {
      allow read: if signedIn() && resource.data.userId == uid();
      allow create, update: if signedIn() &&
        request.resource.data.userId == uid() &&
        request.resource.data.targetUserId is string;
      allow delete: if signedIn() && resource.data.userId == uid();
    }

    match /moderationEvents/{eventId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
