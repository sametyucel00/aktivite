rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function isSelf(userId) {
      return signedIn() && uid() == userId;
    }

    function activityPath(activityId) {
      return /databases/$(database)/documents/activities/$(activityId);
    }

    function activityExists(activityId) {
      return exists(activityPath(activityId));
    }

    function activityData(activityId) {
      return get(activityPath(activityId)).data;
    }

    function isActivityOwner(activityId) {
      return signedIn() &&
        activityExists(activityId) &&
        activityData(activityId).ownerUserId == uid();
    }

    function isRequester() {
      return signedIn() && resource.data.requesterId == uid();
    }

    function createsOwnRequest(activityId, requestId) {
      return signedIn() &&
        requestId == activityId + '__' + uid() &&
        request.resource.data.activityId == activityId &&
        request.resource.data.requesterId == uid() &&
        request.resource.data.message is string &&
        request.resource.data.message.size() > 0 &&
        request.resource.data.status == 'pending';
    }

    function keepsRequestIdentity(activityId) {
      return request.resource.data.activityId == activityId &&
        request.resource.data.requesterId == resource.data.requesterId;
    }

    function updatesOnlyJoinRequestStatusFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'status',
        'workflowStatus',
        'updatedAt'
      ]);
    }

    function isThreadParticipant() {
      return signedIn() && uid() in resource.data.participantIds;
    }

    function createsOwnMessage(threadId) {
      return signedIn() &&
        uid() in get(/databases/$(database)/documents/chatThreads/$(threadId)).data.participantIds &&
        request.resource.data.threadId == threadId &&
        request.resource.data.senderUserId == uid() &&
        request.resource.data.text is string &&
        request.resource.data.text.size() > 0 &&
        request.resource.data.text.size() <= 280;
    }

    function isOwnBlock(blockId) {
      return signedIn() &&
        request.resource.data.userId == uid() &&
        request.resource.data.targetUserId is string &&
        request.resource.data.targetUserId != uid() &&
        blockId == uid() + '-' + request.resource.data.targetUserId &&
        request.resource.data.status == 'active';
    }

    function createsOwnReport() {
      return signedIn() &&
        request.resource.data.userId == uid() &&
        request.resource.data.targetUserId is string &&
        request.resource.data.targetUserId != uid() &&
        request.resource.data.reason is string &&
        request.resource.data.reason in [
          'spam',
          'harassment',
          'unsafe_meetup',
          'fake_profile',
          'inappropriate_content'
        ];
    }

    function createsSafeReminderTrustEvent() {
      return signedIn() &&
        request.resource.data.subjectUserId == uid() &&
        request.resource.data.isUserVisible == true &&
        request.resource.data.reasonCode == 'safe_meetup_reminder_enabled';
    }

    function keepsBlockIdentity(blockId) {
      return isOwnBlock(blockId) &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.targetUserId == resource.data.targetUserId;
    }

    function publicActivityHasNoExactLocation() {
      return !request.resource.data.keys().hasAny([
        'exactLocation',
        'latitude',
        'longitude'
      ]);
    }

    function createsOwnActivity(activityId) {
      return signedIn() &&
        request.resource.data.id == activityId &&
        request.resource.data.ownerUserId == uid() &&
        request.resource.data.title is string &&
        request.resource.data.title.size() > 0 &&
        request.resource.data.description is string &&
        request.resource.data.description.size() > 0 &&
        request.resource.data.city is string &&
        request.resource.data.city.size() > 0 &&
        request.resource.data.approximateLocation is string &&
        request.resource.data.approximateLocation.size() > 0 &&
        publicActivityHasNoExactLocation();
    }

    function updatesOnlyActivityClientFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'participantCount',
        'status',
        'workflowSource',
        'updatedAt'
      ]);
    }

    function keepsActivityImmutableFields(activityId) {
      return request.resource.data.id == activityId &&
        request.resource.data.ownerUserId == resource.data.ownerUserId &&
        request.resource.data.title == resource.data.title &&
        request.resource.data.category == resource.data.category &&
        request.resource.data.description == resource.data.description &&
        request.resource.data.city == resource.data.city &&
        request.resource.data.approximateLocation == resource.data.approximateLocation &&
        request.resource.data.timeLabel == resource.data.timeLabel &&
        request.resource.data.timeOption == resource.data.timeOption &&
        request.resource.data.scheduledAt == resource.data.scheduledAt &&
        request.resource.data.durationMinutes == resource.data.durationMinutes &&
        request.resource.data.maxParticipants == resource.data.maxParticipants &&
        request.resource.data.isIndoor == resource.data.isIndoor &&
        request.resource.data.surfaces == resource.data.surfaces;
    }

    function updatesOnlyChatThreadClientFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'lastMessagePreview',
        'updatedAt'
      ]);
    }

    function keepsChatThreadIdentity() {
      return request.resource.data.activityId == resource.data.activityId &&
        request.resource.data.participantIds == resource.data.participantIds &&
        request.resource.data.safetyBannerVisible == resource.data.safetyBannerVisible;
    }

    match /profiles/{userId} {
      allow read: if signedIn();
      allow create, update: if isSelf(userId) &&
        request.resource.data.id == userId;
      allow delete: if false;
    }

    match /users/{userId}/notificationTokens/{tokenId} {
      allow read, create, update, delete: if isSelf(userId);
    }

    match /activities/{activityId} {
      allow read: if signedIn();
      allow create: if createsOwnActivity(activityId);
      allow update: if signedIn() &&
        resource.data.ownerUserId == uid() &&
        updatesOnlyActivityClientFields() &&
        keepsActivityImmutableFields(activityId) &&
        request.resource.data.ownerUserId == resource.data.ownerUserId &&
        publicActivityHasNoExactLocation();
      allow delete: if signedIn() && resource.data.ownerUserId == uid();

      match /joinRequests/{requestId} {
        allow read: if isActivityOwner(activityId) || isRequester();
        allow create: if createsOwnRequest(activityId, requestId);
        allow update: if keepsRequestIdentity(activityId) &&
          updatesOnlyJoinRequestStatusFields() && (
          (
            isActivityOwner(activityId) &&
            resource.data.status == 'pending' &&
            request.resource.data.status in ['approved', 'rejected']
          ) ||
          (
            isRequester() &&
            resource.data.status == 'pending' &&
            request.resource.data.status == 'cancelled'
          )
        );
        allow delete: if false;
      }
    }

    match /chatThreads/{threadId} {
      allow read: if isThreadParticipant();
      allow create: if false;
      allow update: if isThreadParticipant() &&
        updatesOnlyChatThreadClientFields() &&
        keepsChatThreadIdentity();
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if signedIn() &&
          uid() in get(/databases/$(database)/documents/chatThreads/$(threadId)).data.participantIds;
        allow create: if createsOwnMessage(threadId);
        allow update, delete: if false;
      }
    }

    match /trustEvents/{eventId} {
      allow read: if signedIn() &&
        resource.data.subjectUserId == uid() &&
        resource.data.isUserVisible == true;
      allow create: if createsSafeReminderTrustEvent();
      allow update, delete: if false;
    }

    match /reports/{reportId} {
      allow read: if signedIn() && resource.data.userId == uid();
      allow create: if createsOwnReport();
      allow update, delete: if false;
    }

    match /blocks/{blockId} {
      allow read: if signedIn() && resource.data.userId == uid();
      allow create: if isOwnBlock(blockId);
      allow update: if keepsBlockIdentity(blockId);
      allow delete: if signedIn() && resource.data.userId == uid();
    }

    match /moderationEvents/{eventId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
